<?xml version="1.0"?>
<ruleset name="Cloud Bridge for PMPro">
    <description>WPCS ruleset for Cloud Bridge for PMPro.</description>

    <!-- Scan these paths. -->
    <file>cloud-bridge-for-pmpro.php</file>
    <file>uninstall.php</file>
    <file>src/</file>

    <!-- Exclude vendored and generated files. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/bootstrap.php</exclude-pattern>

    <!-- PHP version target. -->
    <config name="testVersion" value="8.1-"/>

    <!-- Text domain for i18n sniffs. -->
    <config name="text_domain" value="cloud-bridge-for-pmpro"/>

    <!-- WordPress rulesets. -->
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="WordPress-Extra"/>

    <!-- Enforce PSR-4 class file naming. -->
    <rule ref="WordPress.Files.FileName">
        <properties>
            <property name="strict_class_file_names" value="false"/>
        </properties>
    </rule>

    <!-- Allow PSR-4 namespaced classes to not follow WP file-naming conventions. -->
    <rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
        <exclude-pattern>src/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.Files.FileName.InvalidClassFileName">
        <exclude-pattern>src/*</exclude-pattern>
    </rule>

    <!-- Minimum WP version for deprecated function sniffs. -->
    <config name="minimum_supported_wp_version" value="6.4"/>
</ruleset>
